# React Native environment example.
# Copy to .env only if your build tooling reads env files.
# Never commit real secrets.

KIS_ENV=production

# Production apps must use HTTPS/WSS. Keep local LAN HTTP only for debug builds.
KIS_API_BASE_URL=https://api.example.com
KIS_CHAT_BASE_URL=https://chat.example.com
KIS_CHAT_WS_URL=wss://chat.example.com

# Optional feature flags
KIS_EDU_V2=false
