# React Native frontend environment example.
# Copy to .env for local work. Never commit real secrets.
# Run `pnpm run env:sync` after changing .env, or just restart through
# `pnpm start`, `pnpm ios`, or `pnpm android` because those scripts sync first.

KIS_ENV=local

# true: use local defaults when explicit URLs below are empty.
# iOS simulator local default: http://localhost
# Android emulator local default: http://10.0.2.2
KIS_USE_LOCAL_BACKENDS=true
KIS_DEV_BACKEND_HOST=

# Leave blank for local defaults:
#   Django: http://<dev-host>:8000
#   Nest:   http://<dev-host>:4000
KIS_DJANGO_BASE_URL=
KIS_NEST_BASE_URL=
KIS_CHAT_WS_URL=
KIS_CHAT_WS_PATH=/ws

# Render/remote mode:
# KIS_USE_LOCAL_BACKENDS=false
# KIS_DJANGO_BASE_URL=https://kis-django-backend.onrender.com
# KIS_NEST_BASE_URL=https://kis-nest-backend.onrender.com
# KIS_CHAT_WS_URL=https://kis-nest-backend.onrender.com

# Optional feature flags
KIS_EDU_V2=false
# Set to false to bypass AI media-safety scan for all file uploads (testing without AI keys)
KIS_MEDIA_VERIFICATION_ENABLED=false

# Tenor GIF API key — get one free at https://developers.google.com/tenor
# Required for GIF picker in chat. Falls back to demo key in DEV only.
TENOR_API_KEY=
