# Production React Native frontend environment.
# Not read by Metro directly. Before building a release APK, copy this file's
# values into .env, build, then restore your local .env values afterward.

KIS_ENV=production

# Use deployed production backends, not local machine.
KIS_USE_LOCAL_BACKENDS=false
KIS_DEV_BACKEND_HOST=

# Production Django API
KIS_DJANGO_BASE_URL=https://api.kingdomimpactventures.org

# Production Nest / realtime / push notification backend
KIS_NEST_BASE_URL=https://chat.kingdomimpactventures.org

# WebSocket endpoint
KIS_CHAT_WS_URL=https://chat.kingdomimpactventures.org
KIS_CHAT_WS_PATH=/ws

# Media / verification
KIS_MEDIA_VERIFICATION_ENABLED=true

# Suspended by default: register/login skip phone OTP entirely (backend must
# have KIS_PHONE_VERIFICATION_ENABLED set the same way). Set true on both to
# bring phone verification back live.
KIS_PHONE_VERIFICATION_ENABLED=false
