# Local React Native frontend environment.
# This file is ignored by git. Change these values, then restart Metro.

# local = local dev defaults; production = remote defaults unless explicit URLs override.
KIS_ENV=local

# true: use local Django/Nest defaults when explicit URLs below are empty.
# iOS simulator default host: localhost
# Android emulator default host: 10.0.2.2
KIS_USE_LOCAL_BACKENDS=true
KIS_DEV_BACKEND_HOST=10.235.122.99

# Leave blank to use local defaults above:
#   Django: http://<dev-host>:8000
#   Nest:   http://<dev-host>:4000
KIS_DJANGO_BASE_URL=
KIS_NEST_BASE_URL=
KIS_CHAT_WS_URL=
KIS_CHAT_WS_PATH=/ws

# To connect this frontend to Render instead, use:
# KIS_USE_LOCAL_BACKENDS=false
# KIS_DJANGO_BASE_URL=https://kis-django-backend.onrender.com
# KIS_NEST_BASE_URL=https://kis-nest-backend.onrender.com
# KIS_CHAT_WS_URL=https://kis-nest-backend.onrender.com

KIS_MEDIA_VERIFICATION_ENABLED=false

# Suspended by default: register/login skip phone OTP entirely (backend must
# have KIS_PHONE_VERIFICATION_ENABLED set the same way). Set true on both to
# bring phone verification back live.
KIS_PHONE_VERIFICATION_ENABLED=false
