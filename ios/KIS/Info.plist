<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
	<string>KIS</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.kis.app</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>kis</string>
			</array>
		</dict>
	</array>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>kis</string>
		<string>shortcuts</string>
	</array>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>LSSupportsOpeningDocumentsInPlace</key>
	<true/>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoadsInMedia</key>
		<true/>
		<key>NSAllowsLocalNetworking</key>
		<true/>
		<key>NSExceptionDomains</key>
		<dict>
			<key>10.14.20.99</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
				<key>NSIncludesSubdomains</key>
				<true/>
			</dict>
			<key>localhost</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
			</dict>
		</dict>
	</dict>
	<key>NSAppleMusicUsageDescription</key>
	<string>KIS may access your media library to enhance your media experience.</string>
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>KIS may use Bluetooth to detect and connect to nearby devices.</string>
	<key>NSCalendarsUsageDescription</key>
	<string>KIS may use your calendar to help schedule events and activities.</string>
	<key>NSCameraUsageDescription</key>
	<string>KIS uses the camera to let you take photos and videos.</string>
	<key>NSContactsUsageDescription</key>
	<string>KIS may use your contacts to help you discover and connect with friends.</string>
	<key>NSFaceIDUsageDescription</key>
	<string>KIS uses Face ID to securely authenticate you.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>KIS uses your location to improve recommendations and nearby content.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>KIS uses the microphone to record voice messages and calls.</string>
	<key>NSMotionUsageDescription</key>
	<string>KIS uses motion data to offer motion-aware features.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>KIS saves photos and videos you create into your library.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>KIS needs access to your library so you can share existing photos and videos.</string>
	<key>NSRemindersUsageDescription</key>
	<string>KIS may create reminders for events and activities.</string>
	<key>NSSiriUsageDescription</key>
	<string>KIS integrates with Siri to let you perform actions with your voice.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>KIS uses speech recognition to convert your voice to text.</string>
	<key>NSUserNotificationUsageDescription</key>
	<string>KIS uses notifications to alert you of incoming calls and messages.</string>
	<key>RCTNewArchEnabled</key>
	<true/>
	<key>UIAppFonts</key>
	<array>
		<string>Ionicons.ttf</string>
	</array>
	<key>UIBackgroundModes</key>
	<array>
		<string>voip</string>
		<string>audio</string>
		<string>fetch</string>
		<string>remote-notification</string>
	</array>
	<key>UIFileSharingEnabled</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>
	<key>UIRequiresFullScreen</key>
	<true/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<false/>
</dict>
</plist>
