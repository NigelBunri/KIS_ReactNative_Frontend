<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Universal links -->
    <key>com.apple.developer.associated-domains</key>
    <array>
        <string>applinks:kis.app</string>
    </array>

    <!-- VoIP push via PushKit — wakes the app even when killed to show
         the native CallKit incoming call UI on the lock screen.
         Requires this capability to be enabled in your Apple Developer
         portal provisioning profile AND in Xcode → Signing & Capabilities
         → + Capability → Push Notifications + Voice over IP.            -->
    <key>com.apple.developer.pushkit.unrestricted-voip</key>
    <true/>

    <!-- Push Notifications capability (for FCM / APNs) -->
    <key>aps-environment</key>
    <string>development</string>

    <!-- App Group shared with RTCScreenSharingExtension for the
         ReplayKit broadcast socket handoff. Must match the App Group
         configured on the extension target's entitlements. -->
    <key>com.apple.security.application-groups</key>
    <array>
        <string>group.com.kis.broadcast</string>
    </array>
</dict>
</plist>
